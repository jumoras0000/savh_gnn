# ════════════════════════════════════════════════════════════════════
#  Panacée — variables d'environnement (copier en .env, NE PAS committer)
#  Toutes sont OPTIONNELLES : l'app démarre sans, avec des valeurs par défaut.
# ════════════════════════════════════════════════════════════════════

# ── Assistant Claude (onglet Assistant) ──────────────────────────────
# Sans clé, un assistant local prend le relais (appelle quand même les outils).
# La clé peut aussi être saisie directement dans l'UI (stockée en base locale).
ANTHROPIC_API_KEY=

# ── Tableau de bord : emplacement des runs d'entraînement ────────────
# Défaut : <projet>/checkpoints
PANACEE_CKPT_ROOT=

# ── Base SQLite des conversations de l'assistant ─────────────────────
# Défaut : <projet>/webapp/panacee.db
PANACEE_DB=

# ── Suivi TEMPS RÉEL À DISTANCE (entraînement Kaggle → ce dashboard) ──
# À définir CÔTÉ KAGGLE pour que chaque epoch soit poussé vers ton dashboard
# (exposé via un tunnel type ngrok / cloudflared).
#   PANACEE_PUSH_URL   : URL publique de ton dashboard (ex. https://xxxx.ngrok.io)
#   PANACEE_PUSH_RUN   : identifiant du run distant (ex. kaggle_phase2)
#   PANACEE_PUSH_TOKEN : doit correspondre à PANACEE_INGEST_TOKEN ci-dessous
PANACEE_PUSH_URL=
PANACEE_PUSH_RUN=
PANACEE_PUSH_TOKEN=

# ── Sécurité de l'ingestion (côté dashboard) ─────────────────────────
# Si défini, /api/ingest exige ce token (refuse 403 sinon). Fortement
# recommandé dès que le dashboard est exposé sur Internet.
PANACEE_INGEST_TOKEN=

# ── Encodage console (Windows surtout) ───────────────────────────────
PYTHONIOENCODING=utf-8
